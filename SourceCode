// ── İzinli kartlar (UID hex string olarak) ─────────────────
// Kartın UID'sini öğrenmek için Serial monitörü aç, kartı okut
struct Kart {
  const char* uid;
  const char* isim;
};

Kart izinliKartlar[] = {
  {"A1B2C3D4", "user1"},
  {"11223344", "user2"},
  // Buraya yeni kart ekle: {"UIDHEX", "Name lastname"},
};
const int KART_SAYISI = sizeof(izinliKartlar) / sizeof(izinliKartlar[0]);

// ── Servo ──────────────────────────────────────────
#define SERVO_ACIK   90   
