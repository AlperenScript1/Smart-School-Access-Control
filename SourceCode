// ── Log ─────────────────────────────────────────────
struct LogKaydi {
  String isim;
  String uid;
  String zaman;
  bool giris; // true=giriş, false=izinsiz deneme
};

const int MAX_LOG = 100;
LogKaydi loglar[MAX_LOG];
int logSayisi = 0;
bool siradaGiris = true; // giriş/çıkış sırası

MFRC522 rfid(SS_PIN, RST_PIN);
Servo servo;
WebServer server(80);

// ── time ──────────────────────────────────────────
String zamanDamgasi() {
  // Access Point modunda gerçek zaman yok, uptime kullanıyoruz
  unsigned long ms = millis();
  unsigned long sn = ms / 1000;
  unsigned long dk = sn / 60;
  unsigned long sa = dk / 60;
  sn %= 60; dk %= 60;
  char buf[32];
  sprintf(buf, "%02lu:%02lu:%02lu (uptime)", sa, dk, sn);
  return String(buf);
}

// ── Log add ───────────────────────────────────────────────
void logEkle(String isim, String uid, bool giris) {
  if (logSayisi >= MAX_LOG) {
    // Eski kaydı sil (kaydır)
    for (int i = 0; i < MAX_LOG - 1; i++) loglar[i] = loglar[i+1];
    logSayisi = MAX_LOG - 1;
  }
  loglar[logSayisi++] = {isim, uid, zamanDamgasi(), giris};
}

// ── Module card  ──────────────────────────────────────────
String kartUID() {
  String uid = "";
  for (byte i = 0; i < rfid.uid.size; i++) {
    if (rfid.uid.uidByte[i] < 0x10) uid += "0";
    uid += String(rfid.uid.uidByte[i], HEX);
  }
  uid.toUpperCase();
  return uid;
}

String kartIsmi(String uid) {
  for (int i = 0; i < KART_SAYISI; i++) {
    if (uid == String(izinliKartlar[i].uid)) {
      return String(izinliKartlar[i].isim);
    }
  }
  return "";
}

void kapiAc() {
  servo.write(SERVO_ACIK);
  Serial.println("Door open");
}

void kapiKapat() {
  servo.write(SERVO_KAPALI);
  Serial.println("Door closed");
}

