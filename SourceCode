// ── Web server route ───────────────────────────────────
void handleRoot() {
  server.send(200, "text/html", HTML_PAGE);
}

void handleLog() {
  DynamicJsonDocument doc(8192);
  JsonArray arr = doc.to<JsonArray>();
  for (int i = 0; i < logSayisi; i++) {
    JsonObject obj = arr.createNestedObject();
    obj["isim"]  = loglar[i].isim;
    obj["uid"]   = loglar[i].uid;
    obj["zaman"] = loglar[i].zaman;
    obj["giris"] = loglar[i].giris;
  }
  String output;
  serializeJson(doc, output);
  server.send(200, "application/json", output);
}

// ── Setup ──────────────────────────────────────────────────
void setup() {
  Serial.begin(115200);
  SPI.begin();
  rfid.PCD_Init();

  servo.attach(SERVO_PIN);
  kapiKapat();

  // Access Point 
  WiFi.softAP(AP_SSID, AP_PASS);
  Serial.print("AP IP: ");
  Serial.println(WiFi.softAPIP()); // genelde 192.168.4.1

  server.on("/", handleRoot);
  server.on("/api/log", handleLog);
  server.begin();
  Serial.println("Web server baslatildi.");
  Serial.println("Kart okutulmasi bekleniyor...");
}

// ── Loop ───────────────────────────────────────────────────
void loop() {
  server.handleClient();

  if (!rfid.PICC_IsNewCardPresent() || !rfid.PICC_ReadCardSerial()) return;

  String uid = kartUID();
  String isim = kartIsmi(uid);
  Serial.print("Kart: "); Serial.println(uid);

  if (isim != "") {
    Serial.println("Yetkili: " + isim);
    logEkle(isim, uid, true);
    kapiAc();
    // Web server'ı da dinlemeye devam et
    unsigned long t = millis();
    while (millis() - t < BEKLEME_MS) {
      server.handleClient();
    }
    kapiKapat();
  } else {
    Serial.println("YETKISIZ kart: " + uid);
    logEkle("Bilinmeyen", uid, false);
  }

  rfid.PICC_HaltA();
  rfid.PCD_StopCrypto1();
}
